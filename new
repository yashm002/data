import streamlit as st
import pandas as pd
import joblib
import os
import google.generativeai as genai

from dotenv import load_dotenv

# ==================================
# GEMINI SETUP
# ==================================

load_dotenv()

api_key = os.getenv("GEMINI_API_KEY")

genai.configure(api_key=api_key)

gemini_model = genai.GenerativeModel(
    "gemini-2.5-flash"
)

# ==================================
# LOAD MODEL
# ==================================

model = joblib.load("churn_model.pkl")
encoders = joblib.load("encoders.pkl")

# ==================================
# PAGE CONFIG
# ==================================

st.set_page_config(
    page_title="Customer Churn Prediction",
    page_icon="📊",
    layout="wide"
)

st.title("📊 Customer Churn Prediction System")

st.write(
    "Predict customer churn and get AI-powered retention recommendations."
)

# ==================================
# CUSTOMER INPUTS
# ==================================

st.header("Customer Information")

col1, col2 = st.columns(2)

with col1:

    age = st.number_input(
        "Age",
        min_value=18,
        max_value=100,
        value=30
    )

    gender = st.selectbox(
        "Gender",
        ["Male", "Female"]
    )

    tenure = st.number_input(
        "Tenure (Months)",
        min_value=0,
        max_value=100,
        value=12
    )

    monthly_charges = st.number_input(
        "Monthly Charges",
        min_value=0.0,
        value=100.0
    )

with col2:

    contract_type = st.selectbox(
        "Contract Type",
        [
            "Month-to-Month",
            "One-Year",
            "Two-Year"
        ]
    )

    internet_service = st.selectbox(
        "Internet Service",
        [
            "DSL",
            "Fiber Optic",
            "No Internet"
        ]
    )

    tech_support = st.selectbox(
        "Tech Support",
        [
            "Yes",
            "No"
        ]
    )

# ==================================
# PREDICT BUTTON
# ==================================

if st.button("Predict Churn"):

    gender_encoded = encoders[
        "Gender"
    ].transform([gender])[0]

    contract_encoded = encoders[
        "ContractType"
    ].transform([contract_type])[0]

    internet_encoded = encoders[
        "InternetService"
    ].transform([internet_service])[0]

    tech_encoded = encoders[
        "TechSupport"
    ].transform([tech_support])[0]

    total_charges = tenure * monthly_charges

    input_df = pd.DataFrame(
        [[
            age,
            gender_encoded,
            tenure,
            monthly_charges,
            contract_encoded,
            internet_encoded,
            total_charges,
            tech_encoded
        ]],
        columns=[
            'Age',
            'Gender',
            'Tenure',
            'MonthlyCharges',
            'ContractType',
            'InternetService',
            'TotalCharges',
            'TechSupport'
        ]
    )

    prediction = model.predict(
        input_df
    )[0]

    probability = model.predict_proba(
        input_df
    )[0][1]

    st.subheader(
        f"Churn Probability: {probability:.2%}"
    )

    if prediction == 1:

        st.error(
            "⚠️ Customer is likely to churn."
        )

    else:

        st.success(
            "✅ Customer is likely to stay."
        )

    # ==================================
    # GEMINI RETENTION SUGGESTIONS
    # ==================================

    st.divider()

    st.header(
        "🤖 AI Retention Recommendations"
    )

    retention_prompt = f"""
    Customer Details:

    Age: {age}
    Gender: {gender}
    Tenure: {tenure}
    Monthly Charges: {monthly_charges}
    Contract Type: {contract_type}
    Internet Service: {internet_service}
    Tech Support: {tech_support}

    Predicted Churn Probability:
    {probability:.2%}

    Give:

    1. Why this customer may churn
    2. Retention strategies
    3. Personalized offers
    4. Business recommendations

    Keep the answer business-friendly.
    """

    response = gemini_model.generate_content(
        retention_prompt
    )

    st.write(response.text)

# ==================================
# CHATBOT
# ==================================

st.divider()

st.header("💬 Customer Retention Chatbot")

question = st.text_input(
    "Ask a question"
)

if st.button("Ask AI"):

    chatbot_prompt = f"""
    You are a customer retention expert.

    Answer the following question:

    {question}
    """

    response = gemini_model.generate_content(
        chatbot_prompt
    )

    st.write(response.text)
